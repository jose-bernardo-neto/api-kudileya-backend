{
  "name": "api-kudileya-backend",
  "version": "1.0.0",
  "description": "AI Knowledge Base API - REST API for AI-powered knowledge base with FAQs and document management",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "api",
    "knowledge-base",
    "ai",
    "fastify",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "node-cache": "^5.1.2",
    "openai": "^4.67.3",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "proper-lockfile": "^4.1.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.5",
    "@types/proper-lockfile": "^4.1.4",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
